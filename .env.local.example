# ─── Supabase ──────────────────────────────────────────────────────────────────
# Get these from your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Service role key — NEVER expose to the browser. Workers only.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ─── Google Gemini ─────────────────────────────────────────────────────────────
# Get your API key from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# ─── ElevenLabs ────────────────────────────────────────────────────────────────
# Get your API key and voice IDs from https://elevenlabs.io/
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Default voice fallback (used if tone-specific vars are not set)
ELEVENLABS_VOICE_ID=your_default_voice_id_here
# Tone-specific voices (optional — falls back to ELEVENLABS_VOICE_ID)
ELEVENLABS_VOICE_ID_PROFESSIONAL=voice_id_for_professional_tone
ELEVENLABS_VOICE_ID_CONVERSATIONAL=voice_id_for_conversational_tone
ELEVENLABS_VOICE_ID_ENERGETIC=voice_id_for_energetic_tone

# ─── Firecrawl ─────────────────────────────────────────────────────────────────
# Get your API key from https://firecrawl.dev/
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# ─── Upstash Redis (BullMQ job queue) ──────────────────────────────────────────
# Get these from https://console.upstash.com/ → Create Database → Redis
# Use the Redis connection URL (rediss://...), not the REST URL
UPSTASH_REDIS_REST_URL=rediss://your-instance.upstash.io:6380
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# ─── PostHog Analytics ─────────────────────────────────────────────────────────
# Get your key from https://app.posthog.com/
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── App URL ───────────────────────────────────────────────────────────────────
# Used by the worker to call internal API routes.
# Change to your production domain when deploying.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Skyvern (Forked Navigation Agent) ─────────────────────────────────────
# Set USE_SKYVERN=true to use the forked Skyvern for browser recording
# instead of the built-in Playwright recorder.
USE_SKYVERN=false
# Base URL of the self-hosted Skyvern API (Docker Compose runs on port 8000)
SKYVERN_BASE_URL=http://localhost:8080
# API key generated by Skyvern (find in Settings after first boot)
SKYVERN_API_KEY=your_skyvern_api_key_here
